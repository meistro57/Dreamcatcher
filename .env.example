# Database Configuration
DB_PASSWORD=secure_password_here
DATABASE_URL=postgresql://dreamcatcher:dreamcatcher_password@localhost:5432/dreamcatcher
REDIS_URL=redis://localhost:6379

# AI API Keys
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ComfyUI Integration
COMFY_API_URL=http://localhost:8188

# Security
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_base64_32
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ENVIRONMENT=development

# Optional: Voice Processing
WHISPER_MODEL=base
ENABLE_OFFLINE_VOICE=true

# Optional: Development
DEBUG=false
LOG_LEVEL=INFO
ENABLE_SYSTEM_ACTIONS=false
SYSTEM_ACTION_USERS=user,admin
IDEA_PROCESSING_TIMEOUT_MINUTES=15

# Optional: Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Domain Configuration (for production)
DOMAIN=unitthirty2.com
SSL_EMAIL=your_email@example.com
