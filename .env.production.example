# Dreamcatcher production environment template
# Copy to .env and replace all placeholder values before starting production.

# Runtime mode
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
FORCE_HTTPS=true

# Domain and TLS
DOMAIN=example.com
SUBDOMAIN=dreamcatcher
FULL_DOMAIN=dreamcatcher.example.com
SSL_EMAIL=admin@example.com
CORS_ORIGINS=["https://dreamcatcher.example.com"]

# Security
SECRET_KEY=replace_with_a_long_random_secret_key

# Database and cache
DB_PASSWORD=replace_with_strong_db_password
DATABASE_URL=postgresql://dreamcatcher:replace_with_strong_db_password@postgres:5432/dreamcatcher
REDIS_URL=redis://redis:6379

# AI providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_AI_MODEL=claude-3-haiku

# Optional integrations
COMFY_API_URL=http://localhost:8188
ENABLE_METRICS=true
METRICS_PORT=9090

# Optional guarded system controls
ENABLE_SYSTEM_ACTIONS=false
SYSTEM_ACTION_USERS=admin
SYSTEM_ACTION_AUDIT_FILE=./logs/system_actions_audit.jsonl
IDEA_PROCESSING_TIMEOUT_MINUTES=15
